#!/usr/bin/env bash
set -euo pipefail

SEARXNG_BASE_URL="${SEARXNG_BASE_URL:-http://127.0.0.1:8888}"
DEPLOY_DIR="${SEARXNG_DEPLOY_DIR:-/Users/mac/Repository/Services/Local/Tools/SearXNG}"
LIMIT=8
CATEGORY=""
ENGINES=""
LANGUAGE=""
TIME_RANGE=""
PAGE=1
SAFESEARCH=""
TIMEOUT=45
RAW_JSON=0

usage() {
  cat <<'EOF'
Usage: inchheart-search "query" [options]

Options:
  --limit N             Number of results to print, default 8
  --category NAME       SearXNG category, for example general, it, science
  --engines LIST        Specific engines, for example github,stackoverflow,mdn
  --language CODE       Search language, for example auto, en, zh, zh-CN
  --time-range RANGE    day, month, or year when supported by engines
  --page N              Result page number, default 1
  --safesearch LEVEL    0, 1, or 2
  --timeout SECONDS     Request timeout, default 45
  --json                Print raw JSON response
  --help                Show this help

Useful coding queries:
  inchheart-search "!github opencode"
  inchheart-search "!stackoverflow python pathlib glob"
  inchheart-search "!mdn AbortController fetch"
  inchheart-search "site:docs.rs tokio timeout" --engines brave,bing
EOF
}

need_value() {
  local flag="$1"
  local value="${2:-}"
  if [ -z "$value" ]; then
    echo "Error: $flag requires a value" >&2
    exit 2
  fi
}

QUERY_PARTS=()
while [ "$#" -gt 0 ]; do
  case "$1" in
    --limit)
      need_value "$1" "${2:-}"
      LIMIT="$2"
      shift 2
      ;;
    --category|--categories)
      need_value "$1" "${2:-}"
      CATEGORY="$2"
      shift 2
      ;;
    --engines)
      need_value "$1" "${2:-}"
      ENGINES="$2"
      shift 2
      ;;
    --language|--lang)
      need_value "$1" "${2:-}"
      LANGUAGE="$2"
      shift 2
      ;;
    --time-range|--time)
      need_value "$1" "${2:-}"
      TIME_RANGE="$2"
      shift 2
      ;;
    --page|--pageno)
      need_value "$1" "${2:-}"
      PAGE="$2"
      shift 2
      ;;
    --safesearch)
      need_value "$1" "${2:-}"
      SAFESEARCH="$2"
      shift 2
      ;;
    --timeout)
      need_value "$1" "${2:-}"
      TIMEOUT="$2"
      shift 2
      ;;
    --json)
      RAW_JSON=1
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    --)
      shift
      while [ "$#" -gt 0 ]; do
        QUERY_PARTS+=("$1")
        shift
      done
      ;;
    -*)
      echo "Error: unknown option: $1" >&2
      usage >&2
      exit 2
      ;;
    *)
      QUERY_PARTS+=("$1")
      shift
      ;;
  esac
done

if [ "${#QUERY_PARTS[@]}" -eq 0 ]; then
  usage >&2
  exit 2
fi

QUERY="${QUERY_PARTS[*]}"

ensure_service() {
  if curl -fsS -I --max-time 3 "$SEARXNG_BASE_URL/" >/dev/null 2>&1; then
    return 0
  fi

  if [ ! -x "$DEPLOY_DIR/start-searxng.sh" ]; then
    echo "Error: local SearXNG is not responding and start script is missing: $DEPLOY_DIR/start-searxng.sh" >&2
    exit 1
  fi

  "$DEPLOY_DIR/start-searxng.sh" >/dev/null

  for _ in {1..20}; do
    if curl -fsS -I --max-time 3 "$SEARXNG_BASE_URL/" >/dev/null 2>&1; then
      return 0
    fi
    sleep 1
  done

  echo "Error: local SearXNG did not become ready at $SEARXNG_BASE_URL" >&2
  exit 1
}

ensure_service

python3 - "$SEARXNG_BASE_URL" "$QUERY" "$LIMIT" "$CATEGORY" "$ENGINES" "$LANGUAGE" "$TIME_RANGE" "$PAGE" "$SAFESEARCH" "$TIMEOUT" "$RAW_JSON" <<'PY'
import json
import sys
import urllib.error
import urllib.parse
import urllib.request

(
    base_url,
    query,
    limit_s,
    category,
    engines,
    language,
    time_range,
    page_s,
    safesearch,
    timeout_s,
    raw_json_s,
) = sys.argv[1:12]

try:
    limit = max(1, int(limit_s))
    page = max(1, int(page_s))
    timeout = max(1.0, float(timeout_s))
except ValueError as exc:
    print(f"Error: numeric option has invalid value: {exc}", file=sys.stderr)
    raise SystemExit(2)

raw_json = raw_json_s == "1"

params = {
    "q": query,
    "format": "json",
    "pageno": str(page),
}
optional = {
    "categories": category,
    "engines": engines,
    "language": language,
    "time_range": time_range,
    "safesearch": safesearch,
}
params.update({key: value for key, value in optional.items() if value})

url = base_url.rstrip("/") + "/search?" + urllib.parse.urlencode(params)
req = urllib.request.Request(
    url,
    headers={
        "Accept": "application/json",
        "User-Agent": "inchheart-search/1.1 (+local-searxng)",
    },
)

try:
    with urllib.request.urlopen(req, timeout=timeout) as resp:
        body = resp.read().decode("utf-8", errors="replace")
except urllib.error.HTTPError as exc:
    detail = exc.read().decode("utf-8", errors="replace")[:500]
    print(f"Error: SearXNG HTTP {exc.code}: {detail}", file=sys.stderr)
    raise SystemExit(1)
except Exception as exc:
    print(f"Error: SearXNG request failed: {exc}", file=sys.stderr)
    raise SystemExit(1)

try:
    data = json.loads(body)
except json.JSONDecodeError as exc:
    print(f"Error: SearXNG did not return JSON: {exc}", file=sys.stderr)
    print(body[:500], file=sys.stderr)
    raise SystemExit(1)

if raw_json:
    print(json.dumps(data, ensure_ascii=False, indent=2))
    raise SystemExit(0)

def clean(value: object, max_len: int = 600) -> str:
    text = " ".join(str(value or "").split())
    if len(text) <= max_len:
        return text
    return text[: max_len - 1].rstrip() + "..."

def engine_names(item: object) -> str:
    if isinstance(item, list):
        names = []
        for value in item:
            if isinstance(value, list) and value:
                names.append(str(value[0]))
            elif value:
                names.append(str(value))
        return ", ".join(names)
    return str(item or "")

results = data.get("results") or []
print(f"## inchheart-search: {query}")
print(f"URL: {url}\n")

if not results:
    print("No results.")
else:
    for i, item in enumerate(results[:limit], 1):
        title = clean(item.get("title") or "Untitled", 180)
        item_url = clean(item.get("url"), 500)
        content = clean(item.get("content"), 700)
        engines_list = item.get("engines") or item.get("engine")
        published = clean(item.get("publishedDate") or item.get("published_date"), 80)
        print(f"{i}. {title}")
        if item_url:
            print(f"   URL: {item_url}")
        engines_text = engine_names(engines_list)
        if engines_text:
            print(f"   Engines: {engines_text}")
        if published:
            print(f"   Published: {published}")
        if content:
            print(f"   {content}")
        print()

answers = data.get("answers") or []
if answers:
    print("Answers:")
    for answer in answers[:3]:
        print(f"- {clean(answer, 500)}")
    print()

suggestions = data.get("suggestions") or []
if suggestions:
    print("Suggestions:", ", ".join(clean(item, 80) for item in suggestions[:8]))

unresponsive = data.get("unresponsive_engines") or []
if unresponsive:
    print("Unresponsive engines:", engine_names(unresponsive[:8]))
PY
